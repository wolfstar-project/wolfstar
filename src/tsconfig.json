{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"rootDir": "..",
		"noEmit": true,
		"allowJs": true,
		"skipLibCheck": true,
		"resolvePackageJsonImports": true
	},
	"include": [".", "./**/*.json"],
	"exclude": ["./tsconfig.json", "../dist"]
}
